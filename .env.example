# ============================================================
#  Arc-8004 AI Agent Economy — Environment Variables
#  Copy this file to .env and fill in your values.
# ============================================================

# ── Agent Private Keys ────────────────────────────────────────
# Each agent needs a funded Arc Testnet wallet (for gas + USDC).
PRIVATE_KEY_AGENT_A=
PRIVATE_KEY_AGENT_B=
PRIVATE_KEY_AGENT_C=
PRIVATE_KEY_AGENT_D=
PRIVATE_KEY_AGENT_E=
PRIVATE_KEY_AGENT_F=
PRIVATE_KEY_AGENT_G=
PRIVATE_KEY_AGENT_H=
PRIVATE_KEY_AGENT_I=
PRIVATE_KEY_MARKETPLACE=

# ── Treasury ─────────────────────────────────────────────────
# Address that receives USDC from user marketplace payments.
# Must be a funded Arc Testnet wallet you control.
TREASURY_ADDRESS=

# ── Network ──────────────────────────────────────────────────
ARC_RPC_URL=https://5042002.rpc.thirdweb.com

# ── Deployed Contract Addresses ──────────────────────────────
# Fill after running: npm run deploy:arc
# Arc native USDC — do not change
USDC_ADDRESS=0x3600000000000000000000000000000000000000
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
VALIDATION_REGISTRY_ADDRESS=
PAYMENT_ESCROW_ADDRESS=
ARBITRATION_REGISTRY_ADDRESS=
NEGOTIATION_MANAGER_ADDRESS=

# ── Agent Server Ports & URLs ─────────────────────────────────
GATEWAY_PORT=3400
AGENT_B_PORT=3402
AGENT_B_URL=http://localhost:3402
AGENT_C_PORT=3403
AGENT_C_URL=http://localhost:3403
AGENT_D_PORT=3404
AGENT_D_URL=http://localhost:3404
AGENT_E_PORT=3405
AGENT_E_URL=http://localhost:3405
AGENT_F_PORT=3406
AGENT_F_URL=http://localhost:3406
AGENT_G_PORT=3407
AGENT_G_URL=http://localhost:3407
AGENT_H_PORT=3408
AGENT_H_URL=http://localhost:3408
AGENT_I_PORT=3409
AGENT_I_URL=http://localhost:3409

# ── Optional ─────────────────────────────────────────────────
# Comma-separated API keys to restrict agent access (leave blank to disable)
# AGENT_API_KEYS=key1,key2

# Custom SQLite database path (default: agents/data/agent.db)
# AGENT_DB_PATH=/var/data/agent.db
