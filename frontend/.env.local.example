# ============================================================
#  Arc-8004 Frontend — Environment Variables
#  Copy this file to .env.local and fill in your values.
# ============================================================

# URL of the API gateway (backend)
# On VPS, replace localhost with your server's IP or domain
NEXT_PUBLIC_API_URL=http://localhost:3400

# WalletConnect Cloud project ID — required for wallet connections
# Get a free project ID at: https://cloud.walletconnect.com
# Using "demo" works locally but is rate-limited in production
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=demo

# Treasury wallet address — must match TREASURY_ADDRESS in root .env
# This is the address users send USDC to when paying for services
NEXT_PUBLIC_TREASURY_ADDRESS=
